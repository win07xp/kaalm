@startuml gateway-listener-ports
' The single gateway Deployment's four ports, who may call each, and the trust boundary the listener split defends.
' Source of truth: docs/src/gateways/overview.md
!include _style.puml
left to right direction

rectangle "**Untrusted**" as untrusted #line:8B4513;line.dashed {
  rectangle "External\nwebhook callers" as ext #back:FFE4B5;line:8B4513;line.bold;text:3a1f00
  rectangle "**Ingress**\n(user-provisioned)" as ing #back:FFE4B5;line:8B4513;line.bold;text:3a1f00
}

rectangle "**Cluster-internal (trusted)**" as trusted #line:0D47A1;line.dashed {

  rectangle "Agent /\nAgentTask Pods" as pods #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a
  rectangle "Agentry\nController" as ctrl #back:87CEEB;line:0D47A1;line.bold;text:0a2540
  rectangle "kubelet" as kubelet #back:F5F5F5;line:9E9E9E;text:2a0a4a
  rectangle "Prometheus" as prom #back:F5F5F5;line:9E9E9E;text:2a0a4a

  rectangle "**Agentry Gateway Deployment** (agentry-system)" as gw {
    rectangle "**:8443** LLM listener\nVerifyClientCertIfGiven\n....\nLLM proxy paths\nPOST /v1/task/complete\nPOST /v1/agent/heartbeat\nGET /v1/activity\nGET /v1/channels/health" as p8443 #back:90EE90;line:1B5E20;line.bold;text:0b3d0b
    rectangle "**:8080** User listener\nper-AgentChannel auth\n....\n/channels/*\n/v1/channels/responses/*" as p8080 #back:90EE90;line:1B5E20;line.bold;text:0b3d0b
    rectangle "**:8081** health\nTLS, no client auth\n....\n/healthz  /readyz" as p8081 #back:F5F5F5;line:9E9E9E;text:2a0a4a
    rectangle "**:9090** metrics\nunauthenticated in-cluster\n....\n/metrics" as p9090 #back:F5F5F5;line:9E9E9E;text:2a0a4a
  }
}

ext -[#8B4513,bold]-> ing
ing -[#8B4513,bold]-> p8080 : untrusted traffic
pods -[#4A148C,bold]-> p8443 : mTLS SAN always.\nSA bearer only on the\nLLM proxy paths: the two\nagent-report paths are\nmTLS-only.
ctrl -[#0D47A1,bold]-> p8443 : mTLS,\ncontroller SAN
kubelet -[#9E9E9E]-> p8081 : probes
prom -[#9E9E9E]-> p9090 : scrape

ing .[#B71C1C,bold]. p8443 : **NO ROUTE**\ncontroller-only paths\nare not on :8080

legend bottom
  The listener split is the security argument.
  **:8080 hosts no mTLS-authenticated path**, so an Ingress fronting it
  cannot reach an endpoint whose authorization assumes a controller-SAN
  client cert. Probes get their own port for the same reason: both :8443
  and :8080 are reachable beyond the boundary that would make cert-less
  probe coexistence safe.
endlegend
@enduml
