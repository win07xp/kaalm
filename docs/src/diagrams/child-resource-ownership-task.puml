@startuml child-resource-ownership-task
' Who owns each AgentTask child resource, and the one link that cannot be an ownerRef at all.
' Source of truth: docs/src/runtime/child-resources.md
!include _style.puml
left to right direction

skinparam nodesep 14
skinparam ranksep 60
skinparam rectangle {
  roundCorner 4
}

rectangle "namespace: **team-support**" as ns #line:4A148C;line.dashed;text:2a0a4a {

  rectangle "**AgentTask**\nnightly-report\nfinalizer: kaalm.io/task-finalizer" as task #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a

  rectangle "**Pod**\nephemeral, no listener" as pod #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a
  rectangle "**PVC**\nonly if the task spec\nrequests persistence" as pvc #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a
  rectangle "**ServiceAccount**\ntask-{taskName}\nno RoleBindings by default" as sa #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a
  rectangle "**NetworkPolicy**\negress allow set only,\n**no ingress allow rules**" as np #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a
  rectangle "**Certificate** {taskName}-tls\n**client auth only**\n(no listener to serve)" as cert #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a

  rectangle "**Secret** {taskName}-tls" as secret #back:FFD580;line:7a3f00;line.bold;text:3a1f00

  rectangle "only when completion.condition: **agentReported**" as reported #line:9E9E9E;line.dashed;text:555555 {
    rectangle "**ConfigMap**\n{taskName}-completion\npre-created, data: {}" as cm #back:FFD580;line:7a3f00;line.bold;text:3a1f00
    rectangle "**Role** + **RoleBinding**\nname-scoped update/patch\nfor the gateway SA" as rbac #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a
  }

  rectangle "**no Service**\ntasks receive no channel\nmessages and have no\nstable endpoint" as nosvc #back:F5F5F5;line:9E9E9E;line.dashed;text:555555
}

task -[#4A148C,bold]-> pod
task -[#4A148C,bold]-> pvc
task -[#4A148C,bold]-> sa
task -[#4A148C,bold]-> np
task -[#4A148C,bold]-> cert
task -[#4A148C,bold]-> cm
task -[#4A148C,bold]-> rbac

cert -[#7a3f00,bold]-> secret : writes + owns

task -[hidden]-> nosvc

note bottom of task
  Every AgentTask child carries an ownerRef, so
  cascade GC removes all of them. The task finalizer
  only terminates the Pod gracefully; unlike the
  Agent and AgentChannel finalizers,
  **it sweeps nothing and rewrites no ownerRef.**
end note

legend bottom
  **Solid purple** = ownerRef, so cascade GC collects it on AgentTask deletion
  **Solid brown** = owned by cert-manager, one hop further out
endlegend
@enduml
