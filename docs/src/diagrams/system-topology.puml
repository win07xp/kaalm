@startuml system-topology
' Agentry system topology.
' Source of truth: docs/src/concepts/system-architecture.md
!include _style.puml
left to right direction

' -- Inbound external --------------------------------------
rectangle "Webhook Callers\n(external)" as webhooks #back:FFE4B5;line:8B4513;line.bold;text:3a1f00

' -- Agentry Gateway (agentry-system) ----------------------
rectangle "**Agentry Gateway Pod**\nagentry-system\n:8080 user · :8443 LLM" as gw #back:90EE90;line:1B5E20;line.bold;text:0b3d0b

' -- User namespaces (agent + workload pods) ---------------
rectangle "User namespaces" as users {
  rectangle "**Agent Pod**\n(Agentry-managed)" as agentC #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a
  rectangle "**AgentTask Pod**\n(managed, ephemeral)" as agentTaskC #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a
  rectangle "**Workload Pod**\n(gateway-only, BYO)" as workloadC #back:E6E6FA;line:4A148C;line.bold;text:2a0a4a
}

' -- Outbound external -------------------------------------
rectangle "LLM Provider APIs\n(Anthropic, OpenAI)" as providers #back:FFE4B5;line:8B4513;line.bold;text:3a1f00
rectangle "Callback URLs\n(async responses)" as callbacks #back:FFE4B5;line:8B4513;line.bold;text:3a1f00

' -- Controller + apiserver (control plane) ----------------
rectangle "Agentry Controller\nagentry-system" as ctrl {
  rectangle "**Reconcilers**\nAgent, AgentTask,\nModelProvider,\nAgentClass, AgentChannel" as recs #back:87CEEB;line:0D47A1;line.bold;text:0a2540
  rectangle "**Activator**" as activator #back:87CEEB;line:0D47A1;line.bold;text:0a2540
}
database "Kubernetes API" as apiserver

' -- Data plane (thick) ------------------------------------
webhooks -[#1B5E20,bold]-> gw : inbound :8080
gw -[#1B5E20,bold]-> agentC : deliver (mTLS)\n/v1/message
gw -[#1B5E20,bold]-> callbacks : callback (HTTPS)\ncallbackUrl
agentC -[#1B5E20,bold]-> gw : LLM (mTLS)
agentTaskC -[#1B5E20,bold]-> gw : LLM (mTLS)
workloadC -[#1B5E20,bold]-> gw : LLM (SA Bearer)
gw -[#1B5E20,bold]-> providers : egress

' -- Lifecycle (thin) --------------------------------------
ctrl -[#0D47A1]-> apiserver : watches / reconciles
apiserver -[#0D47A1]-> users : Pods, PVCs, Services,\nConfigMaps, NetworkPolicies,\nServiceAccounts, Certificates

' -- Internal mTLS RPCs (dashed) ---------------------------
gw .[#4A148C].> activator : /v1/activate :9443
ctrl .[#4A148C].> gw : /v1/activity
ctrl .[#4A148C].> gw : /v1/channels/health
agentC .[#4A148C].> gw : /v1/agent/heartbeat
agentTaskC .[#4A148C].> gw : /v1/task/complete

legend bottom
  Thick green = data plane | Thin blue = lifecycle
  Dashed purple = internal mTLS RPC, on :8443 unless noted
endlegend
@enduml
